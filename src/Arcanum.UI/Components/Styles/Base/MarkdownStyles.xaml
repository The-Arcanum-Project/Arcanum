<ResourceDictionary xmlns = "http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x = "http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:md = "clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source = "/Arcanum_UI;component/Assets/ArcanumShared/DefaultPalette.xaml" />
        <ResourceDictionary Source = "/Arcanum_UI;component/Assets/ArcanumShared/DefaultFonts.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType = "md:MarkdownViewer">
        <Setter Property = "Template">
            <Setter.Value>
                <ControlTemplate TargetType = "md:MarkdownViewer">
                    <FlowDocumentScrollViewer Document = "{TemplateBinding Document}"
                                              ScrollViewer.VerticalScrollBarVisibility = "Auto" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType = "{x:Type FlowDocument}" x:Key = "{x:Static md:Styles.DocumentStyleKey}">
        <Setter Property = "Foreground" Value = "{StaticResource DefaultForeColorBrush}" />
        <Setter Property = "FontFamily" Value = "{StaticResource DefaultFont}" />
        <Setter Property = "FontSize" Value = "{StaticResource DefaultFontSize}" />
        <Setter Property = "TextAlignment" Value = "Left" />
        <Setter Property = "PagePadding" Value = "15" />
    </Style>

    <!-- Paragraph Style -->
    <Style TargetType = "{x:Type Paragraph}" x:Key = "{x:Static md:Styles.ParagraphStyleKey}">
        <Setter Property = "Margin" Value = "0,0,0,10" />
        <Setter Property = "LineHeight" Value = "20" />
    </Style>

    <!-- Headings (Using Paragraph as target) -->
    <Style TargetType = "{x:Type Paragraph}" x:Key = "{x:Static md:Styles.Heading1StyleKey}">
        <Setter Property = "FontSize" Value = "32" />
        <Setter Property = "Foreground" Value = "{StaticResource DefaultForeColorBrush}" />
        <Setter Property = "FontWeight" Value = "Bold" />
        <Setter Property = "Margin" Value = "0,15,0,10" />
    </Style>

    <Style TargetType = "{x:Type Paragraph}" x:Key = "{x:Static md:Styles.Heading2StyleKey}">
        <Setter Property = "FontSize" Value = "24" />
        <Setter Property = "Foreground" Value = "{StaticResource DefaultForeColorBrush}" />
        <Setter Property = "FontWeight" Value = "SemiBold" />
        <Setter Property = "Margin" Value = "0, 0, 0, 8" />
    </Style>

    <Style TargetType = "{x:Type Paragraph}" x:Key = "{x:Static md:Styles.Heading3StyleKey}">
        <Setter Property = "FontSize" Value = "20" />
        <Setter Property = "Foreground" Value = "{StaticResource DefaultForeColorBrush}" />
        <Setter Property = "FontWeight" Value = "SemiBold" />
        <Setter Property = "Margin" Value = "0, 0, 0, 7" />
    </Style>

    <Style TargetType = "{x:Type Paragraph}" x:Key = "{x:Static md:Styles.Heading4StyleKey}">
        <Setter Property = "FontSize" Value = "18" />
        <Setter Property = "Foreground" Value = "{StaticResource DefaultForeColorBrush}" />
        <Setter Property = "FontWeight" Value = "SemiBold" />
        <Setter Property = "Margin" Value = "0, 0, 0, 5" />
    </Style>

    <Style TargetType = "{x:Type Paragraph}" x:Key = "{x:Static md:Styles.Heading5StyleKey}">
        <Setter Property = "FontSize" Value = "16" />
        <Setter Property = "Foreground" Value = "{StaticResource DefaultForeColorBrush}" />
        <Setter Property = "FontWeight" Value = "SemiBold" />
        <Setter Property = "Margin" Value = "0, 0, 0, 3" />
    </Style>

    <Style TargetType = "{x:Type Paragraph}" x:Key = "{x:Static md:Styles.Heading6StyleKey}">
        <Setter Property = "FontSize" Value = "15" />
        <Setter Property = "Foreground" Value = "{StaticResource DefaultForeColorBrush}" />
        <Setter Property = "FontWeight" Value = "SemiBold" />
        <Setter Property = "Margin" Value = "0, 0, 0, 2" />
    </Style>

    <!-- Hyperlinks -->
    <Style TargetType = "{x:Type Hyperlink}" x:Key = "{x:Static md:Styles.HyperlinkStyleKey}">
        <Setter Property = "Foreground" Value = "{StaticResource BlueAccentColorBrush}" />
        <Setter Property = "ToolTipService.ShowOnDisabled" Value = "True" />
        <Setter Property = "TextDecorations" Value = "None" />
        <Style.Triggers>
            <Trigger Property = "IsMouseOver" Value = "True">
                <Setter Property = "TextDecorations" Value = "Underline" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Quote Blocks -->
    <Style TargetType = "{x:Type Section}" x:Key = "{x:Static md:Styles.QuoteBlockStyleKey}">
        <Setter Property = "Background" Value = "{StaticResource BlueComplementaryBackColorBrush}" />
        <Setter Property = "BorderBrush" Value = "{StaticResource BlueAccentColorBrush}" />
        <Setter Property = "BorderThickness" Value = "4,0,0,0" />
        <Setter Property = "Padding" Value = "8,5,8,0" />
        <Setter Property = "Margin" Value = "10,7,0,7" />
    </Style>

    <!-- Horizontal Separators  -->
    <Style TargetType = "{x:Type Line}" x:Key = "{x:Static md:Styles.ThematicBreakStyleKey}">
        <Setter Property = "Stroke" Value = "{StaticResource DefaultBorderColorBrush}" />
        <Setter Property = "StrokeThickness" Value = "1" />
        <Setter Property = "Stretch" Value = "Fill" />
        <Setter Property = "X2" Value = "1" />
        <Setter Property = "Margin" Value = "0,10,0,10" />
    </Style>

    <!-- Inline Code -->
    <Style TargetType = "{x:Type Run}" x:Key = "{x:Static md:Styles.CodeStyleKey}">
        <Setter Property = "FontFamily" Value = "{StaticResource DefaultMonospacedFont}" />
        <Setter Property = "Background" Value = "{StaticResource LightBackColorBrush}" />
        <Setter Property = "Foreground" Value = "{StaticResource LightGrayAccentColorBrush}" />
    </Style>

    <!-- Code Blocks -->
    <Style TargetType = "{x:Type Paragraph}" x:Key = "{x:Static md:Styles.CodeBlockStyleKey}">
        <Setter Property = "FontFamily" Value = "{StaticResource DefaultMonospacedFont}" />
        <Setter Property = "Background" Value = "{StaticResource LightBackColorBrush}" />
        <Setter Property = "Padding" Value = "10" />
    </Style>

    <!-- Images -->
    <Style TargetType = "{x:Type Image}" x:Key = "{x:Static md:Styles.ImageStyleKey}">
        <Setter Property = "Stretch" Value = "Uniform" />
        <Setter Property = "MaxWidth" Value = "800" />
    </Style>


</ResourceDictionary>