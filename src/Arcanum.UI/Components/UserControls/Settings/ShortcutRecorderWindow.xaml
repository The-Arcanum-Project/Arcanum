<Window x:Class = "Arcanum.UI.Components.UserControls.Settings.ShortcutRecorderWindow"
        xmlns = "http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x = "http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc = "http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d = "http://schemas.microsoft.com/expression/blend/2008"
        xmlns:styleClasses = "clr-namespace:Arcanum.UI.Components.StyleClasses"
        xmlns:settings = "clr-namespace:Arcanum.UI.Components.UserControls.Settings"
        xmlns:converters = "clr-namespace:Arcanum.UI.Components.Converters" mc:Ignorable = "d" WindowStyle = "None"
        ResizeMode = "NoResize" Width = "400" Background = "Transparent" WindowStartupLocation = "CenterOwner"
        ShowInTaskbar = "False" AllowsTransparency = "True" SizeToContent = "Height" MinHeight = "170"
        d:DataContext = "{d:DesignInstance settings:ShortcutRecorderViewModel}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source = "/Arcanum_UI;component/Assets/ArcanumShared/DefaultPalette.xaml" />
                <ResourceDictionary Source = "/Arcanum_UI;component/Assets/ArcanumShared/DefaultFonts.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:GestureToTextConverter x:Key = "GestureToTextConverter" />
            <converters:CountToVisibilityConverter x:Key = "CountToVisibilityConverter" />
            <converters:InvertedCountToVisibilityConverter x:Key = "InvertedCountToVisibilityConverter" />
            <converters:BoolToVisibilityConverter x:Key = "BoolToVisibilityConverter" />
        </ResourceDictionary>

    </Window.Resources>

    <Border Background = "{StaticResource DefaultBackColorBrush}"
            BorderBrush = "{StaticResource DefaultBorderColorBrush}" CornerRadius = "8" BorderThickness = "2"
            Padding = "5">
        <DockPanel>
            <!-- Header -->
            <StackPanel Orientation = "Horizontal" Margin = "8,5,0,5" DockPanel.Dock = "Top">
                <TextBlock Text = "{Binding CommandName}" Foreground = "{StaticResource LightForeColorBrush}"
                           FontWeight = "Bold" FontSize = "14" />
                <TextBlock Text = " - " FontSize = "14" />
                <TextBlock Text = "{Binding CommandId}" FontSize = "12" Margin = "0,1,0,0"
                           Foreground = "{StaticResource LightGrayAccentColorBrush}" VerticalAlignment = "Bottom" />
            </StackPanel>

            <TextBlock DockPanel.Dock = "Top" FontSize = "12" Text = "{Binding CommandDescription}"
                       Margin = "8, 0, 0, 3" TextWrapping = "Wrap" />

            <!-- Separator -->
            <Border BorderBrush = "{StaticResource DefaultBorderColorBrush}" BorderThickness = "0,0,0,2" Margin = "4"
                    DockPanel.Dock = "Top" />

            <!-- First Stroke Input -->
            <Grid Margin = "3,5,8,5" HorizontalAlignment = "Stretch" DockPanel.Dock = "Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width = "Auto" />
                    <ColumnDefinition Width = "*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height = "Auto" />
                    <RowDefinition Height = "4" />
                    <RowDefinition Height = "Auto" />
                </Grid.RowDefinitions>

                <!-- First Stroke Text -->
                <TextBlock Grid.Row = "0" Grid.Column = "0" VerticalAlignment = "Center" Margin = "5,0,15,0"
                           Text = "First Stroke:" />

                <Border Grid.Row = "0" Grid.Column = "1" x:Name = "FirstInput"
                        Background = "{StaticResource DarkBackColorBrush}" BorderThickness = "1" CornerRadius = "3"
                        Padding = "8,4" MouseDown = "Input_MouseDown" Tag = "0" DockPanel.Dock = "Top">
                    <Border.Style>
                        <Style TargetType = "Border">
                            <Setter Property = "BorderBrush" Value = "{StaticResource DefaultBorderColorBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding = "{Binding ActiveSlotIndex}" Value = "0">
                                    <Setter Property = "BorderBrush" Value = "{StaticResource BlueAccentColorBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <TextBlock Text = "{Binding FirstStroke, Converter={StaticResource GestureToTextConverter}}"
                                   FontSize = "13" />
                        <TextBlock Text = "+" HorizontalAlignment = "Right" />
                    </Grid>
                </Border>

                <!-- Second Stroke Toggle & Input -->
                <CheckBox Grid.Row = "2" Grid.Column = "0" IsChecked = "{Binding IsSecondStrokeEnabled}"
                          VerticalAlignment = "Center" Margin = "5,0,15,0" Content = "Second Stroke:"
                          HorizontalContentAlignment = "Left" Checked = "ToggleButton_OnChecked" />

                <Border Grid.Row = "2" Grid.Column = "1" x:Name = "SecondInput"
                        Background = "{StaticResource DarkBackColorBrush}" BorderThickness = "1" CornerRadius = "3"
                        Padding = "8,4" MouseDown = "Input_MouseDown" Tag = "1"
                        IsEnabled = "{Binding IsSecondStrokeEnabled}" HorizontalAlignment = "Stretch">
                    <Border.Style>
                        <Style TargetType = "Border">
                            <Setter Property = "BorderBrush" Value = "{StaticResource DefaultBorderColorBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding = "{Binding ActiveSlotIndex}" Value = "1">
                                    <Setter Property = "BorderBrush" Value = "{StaticResource BlueAccentColorBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid HorizontalAlignment = "Stretch">
                        <TextBlock Text = "{Binding SecondStroke, Converter={StaticResource GestureToTextConverter}}"
                                   FontSize = "13" HorizontalAlignment = "Stretch" />
                        <TextBlock Text = "+" HorizontalAlignment = "Right" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Separator -->
            <Border BorderBrush = "{StaticResource DefaultBorderColorBrush}" BorderThickness = "0,0,0,2" Margin = "4"
                    DockPanel.Dock = "Top" />


            <StackPanel Orientation = "Horizontal" Margin = "0,10,0,0" DockPanel.Dock = "Top"
                        Visibility = "{Binding HasValidationError, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text = "❌" Margin = "0,0,5,0" />
                <TextBlock Text = "{Binding ValidationError}" Foreground = "{StaticResource DimErrorRedColorBrush}"
                           FontWeight = "Bold" />
            </StackPanel>

            <!-- Conflict Section -->
            <StackPanel Visibility = "{Binding Conflicts.Count, Converter={StaticResource CountToVisibilityConverter}}"
                        Margin = "5,5,0,0" DockPanel.Dock = "Top">


                <StackPanel Orientation = "Horizontal" Margin = "0,0,0,5">
                    <TextBlock Text = "⚠️" Margin = "0,0,5,0" Foreground = "{StaticResource DarkYellowColorBrush}" />
                    <TextBlock Text = "Already assigned to:" Foreground = "{StaticResource DarkYellowColorBrush}" />
                </StackPanel>

                <ScrollViewer MaxHeight = "120" VerticalScrollBarVisibility = "Auto">
                    <ItemsControl ItemsSource = "{Binding Conflicts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation = "Horizontal" Margin = "15,2">
                                    <TextBlock Text = " - " Foreground = "{StaticResource LightForeColorBrush}" />
                                    <TextBlock Text = "{Binding ConflictingCommandName}" FontWeight = "Bold" />
                                    <TextBlock Text = " in " Foreground = "{StaticResource LightForeColorBrush}" />
                                    <TextBlock Text = "{Binding ConflictingCommandId}"
                                               Foreground = "{StaticResource LightGrayAccentColorBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <TextBlock
                Visibility = "{Binding Conflicts.Count, Converter={StaticResource InvertedCountToVisibilityConverter}}"
                HorizontalAlignment = "Center" Text = "No Conflicts found." DockPanel.Dock = "Top"
                Margin = "0, 4, 0, 0" Foreground = "{StaticResource GreenForeColorBrush}" />

            <!-- Buttons -->
            <StackPanel Orientation = "Horizontal" HorizontalAlignment = "Right" VerticalAlignment = "Bottom"
                        Margin = "0, 5, 0, 0" DockPanel.Dock = "Bottom">
                <styleClasses:BaseButton Content = "Cancel" Click = "Cancel_Click" Margin = "5,0" Width = "80"
                                         Height = "25" />
                <styleClasses:BaseButton Content = "OK" Click = "Ok_Click" Width = "80" Height = "25"
                                         IsEnabled = "{Binding IsSelectionValid}" />
            </StackPanel>
        </DockPanel>
    </Border>
</Window>