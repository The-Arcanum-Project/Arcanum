<Window x:Class = "Arcanum.UI.Components.UserControls.Settings.ShortcutRecorderWindow"
        xmlns = "http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x = "http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc = "http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d = "http://schemas.microsoft.com/expression/blend/2008"
        xmlns:styleClasses = "clr-namespace:Arcanum.UI.Components.StyleClasses"
        xmlns:settings = "clr-namespace:Arcanum.UI.Components.UserControls.Settings"
        xmlns:converters = "clr-namespace:Arcanum.UI.Components.Converters" mc:Ignorable = "d" WindowStyle = "None"
        ResizeMode = "NoResize" Width = "400" Height = "200" Background = "Transparent"
        WindowStartupLocation = "CenterOwner" ShowInTaskbar = "False" AllowsTransparency = "True"
        d:DataContext = "{d:DesignInstance settings:ShortcutRecorderViewModel}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source = "/Arcanum_UI;component/Assets/ArcanumShared/DefaultPalette.xaml" />
                <ResourceDictionary Source = "/Arcanum_UI;component/Assets/ArcanumShared/DefaultFonts.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:GestureToTextConverter x:Key = "GestureToTextConverter" />
            <converters:CountToVisibilityConverter x:Key = "CountToVisibilityConverter" />
            <converters:InvertedCountToVisibilityConverter x:Key = "InvertedCountToVisibilityConverter" />
        </ResourceDictionary>

    </Window.Resources>

    <Border Background = "{StaticResource LightBackColorBrush}"
            BorderBrush = "{StaticResource DefaultBorderColorBrush}" CornerRadius = "3" BorderThickness = "2"
            Padding = "5">
        <DockPanel LastChildFill = "True">
            <!-- Header -->
            <StackPanel Orientation = "Horizontal" Margin = "0,5,0,5" DockPanel.Dock = "Top">
                <TextBlock Text = "{Binding CommandName}" Foreground = "{StaticResource LightForeColorBrush}"
                           FontWeight = "Bold" FontSize = "14" />
                <TextBlock Text = " in " FontSize = "14" />
                <TextBlock Text = "{Binding CommandScope}" FontSize = "14" />
            </StackPanel>

            <!-- First Stroke Input -->
            <Border x:Name = "FirstInput" Background = "{StaticResource DarkBackColorBrush}" BorderThickness = "1"
                    CornerRadius = "3" Padding = "8,4" MouseDown = "Input_MouseDown" Tag = "0" DockPanel.Dock = "Top">
                <Border.Style>
                    <Style TargetType = "Border">
                        <Setter Property = "BorderBrush" Value = "{StaticResource DefaultBorderColorBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding = "{Binding ActiveSlotIndex}" Value = "0">
                                <Setter Property = "BorderBrush" Value = "{StaticResource BlueAccentColorBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <TextBlock Text = "{Binding FirstStroke, Converter={StaticResource GestureToTextConverter}}"
                               FontSize = "13" />
                    <TextBlock Text = "+" HorizontalAlignment = "Right" />
                </Grid>
            </Border>

            <!-- Second Stroke Toggle & Input -->
            <Grid Margin = "0,5,0,5" HorizontalAlignment = "Stretch" DockPanel.Dock = "Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width = "Auto" />
                    <ColumnDefinition Width = "*" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column = "0" IsChecked = "{Binding IsSecondStrokeEnabled}" VerticalAlignment = "Center"
                          Margin = "5,0,15,0" Content = "Second Stroke:" />

                <Border Grid.Column = "1" x:Name = "SecondInput" Background = "{StaticResource DarkBackColorBrush}"
                        BorderThickness = "1" CornerRadius = "3" Padding = "8,4" MouseDown = "Input_MouseDown"
                        Tag = "1" IsEnabled = "{Binding IsSecondStrokeEnabled}" HorizontalAlignment = "Stretch">
                    <Border.Style>
                        <Style TargetType = "Border">
                            <Setter Property = "BorderBrush" Value = "{StaticResource DefaultBorderColorBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding = "{Binding ActiveSlotIndex}" Value = "1">
                                    <Setter Property = "BorderBrush" Value = "{StaticResource BlueAccentColorBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid HorizontalAlignment = "Stretch">
                        <TextBlock Text = "{Binding SecondStroke, Converter={StaticResource GestureToTextConverter}}"
                                   FontSize = "13" HorizontalAlignment = "Stretch" />
                        <TextBlock Text = "+" HorizontalAlignment = "Right" Foreground = "Gray" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Conflict Section -->
            <StackPanel Visibility = "{Binding Conflicts.Count, Converter={StaticResource CountToVisibilityConverter}}"
                        Margin = "0,20,0,0" DockPanel.Dock = "Top">
                <StackPanel Orientation = "Horizontal" Margin = "0,0,0,5">
                    <TextBlock Text = "⚠️" Margin = "0,0,5,0" />
                    <TextBlock Text = "Already assigned to:" />
                </StackPanel>

                <ScrollViewer MaxHeight = "120" VerticalScrollBarVisibility = "Auto">
                    <ItemsControl ItemsSource = "{Binding Conflicts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation = "Horizontal" Margin = "15,2">
                                    <TextBlock Text = "{Binding ConflictingCommandName}" />
                                    <TextBlock Text = " in " Foreground = "{StaticResource LightForeColorBrush}" />
                                    <TextBlock Text = "{Binding Scope}"
                                               Foreground = "{StaticResource LightForeColorBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <TextBlock
                Visibility = "{Binding Conflicts.Count, Converter={StaticResource InvertedCountToVisibilityConverter}}"
                HorizontalAlignment = "Left" Text = "No Conflicts found." DockPanel.Dock = "Top">
            </TextBlock>

            <!-- Buttons -->
            <StackPanel Orientation = "Horizontal" HorizontalAlignment = "Right" VerticalAlignment = "Bottom"
                        Margin = "0, 5, 0, 0" DockPanel.Dock = "Bottom">
                <styleClasses:BaseButton Content = "Cancel" Click = "Cancel_Click" Margin = "5,0" Width = "80"
                                         Height = "25" />
                <styleClasses:BaseButton Content = "OK" Click = "Ok_Click" Width = "80" Height = "25" />
            </StackPanel>

            <Border Background = "Transparent" />
        </DockPanel>
    </Border>
</Window>