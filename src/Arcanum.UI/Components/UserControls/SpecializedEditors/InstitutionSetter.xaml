<UserControl x:Class = "Arcanum.UI.Components.UserControls.SpecializedEditors.InstitutionSetter"
             xmlns = "http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x = "http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc = "http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d = "http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vMs = "clr-namespace:Arcanum.UI.Components.UserControls.SpecializedEditors.VMs"
             xmlns:styleClasses = "clr-namespace:Arcanum.UI.Components.StyleClasses" mc:Ignorable = "d"
             d:DesignHeight = "30" d:DesignWidth = "200" d:DataContext = "{d:DesignInstance vMs:InstitutionSetterVm}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source = "/Arcanum_UI;component/Assets/ArcanumShared/DefaultGeometry.xaml" />
                <ResourceDictionary Source = "/Arcanum_UI;component/Assets/ArcanumShared/DefaultPalette.xaml" />
                <ResourceDictionary Source = "/Arcanum_UI;component/Assets/ArcanumShared/DefaultFonts.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key = "PresenceIconStyle" TargetType = "ContentControl">
                <!-- Default State (None) -->
                <Setter Property = "ContentTemplate">
                    <Setter.Value>
                        <DataTemplate>
                            <Path x:Name = "IconPath" Data = "{StaticResource Institution.NoneState}"
                                  Stroke = "{StaticResource DisabledForeColorBrush}" StrokeThickness = "1.8"
                                  StrokeStartLineCap = "Round" StrokeEndLineCap = "Round" Width = "15" Height = "15"
                                  Stretch = "Uniform" />
                        </DataTemplate>
                    </Setter.Value>
                </Setter>

                <Style.Triggers>
                    <!-- Mixed State -->
                    <DataTrigger Binding = "{Binding State}" Value = "{x:Static vMs:PresenceState.Mixed}">
                        <Setter Property = "ContentTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <Path Data = "{StaticResource Institution.MixedState}"
                                          Stroke = "{StaticResource DarkYellowColorBrush}" StrokeThickness = "1.8"
                                          Width = "15" Height = "15" Stretch = "Uniform" />
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>

                    <!-- All State -->
                    <DataTrigger Binding = "{Binding State}" Value = "{x:Static vMs:PresenceState.All}">
                        <Setter Property = "ContentTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <Path Data = "{StaticResource Institution.AllState}"
                                          Stroke = "{StaticResource GreenColorBrush}" StrokeThickness = "1.8"
                                          StrokeStartLineCap = "Round" StrokeEndLineCap = "Round"
                                          StrokeLineJoin = "Round" Width = "15" Height = "15" Stretch = "Uniform" />
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border BorderBrush = "{StaticResource DefaultBorderColorBrush}" BorderThickness = "0, 1, 0, 0">
        <DockPanel LastChildFill = "True" Margin = "5,1">
            <!-- Remove from all Button -->
            <styleClasses:BaseButton Width = "21" Height = "21" Margin = "0,0,5,0"
                                     Command = "{Binding SetInNoneCommand}">
                <Image Source = "/Arcanum_UI;component/Assets/Icons/20x20/Minimize20x20.png" />
                <styleClasses:BaseButton.ToolTip>
                    <TextBlock>
                        <Run Text = "Remove this Institution from all locations. (Filters apply)" />
                    </TextBlock>
                </styleClasses:BaseButton.ToolTip>
            </styleClasses:BaseButton>

            <!-- Presence Icon -->
            <ContentControl Style = "{StaticResource PresenceIconStyle}" Margin = "0,0,5,0" Height = "15" Width = "15"
                            VerticalAlignment = "Center" HorizontalAlignment = "Center" />

            <!-- Add to all Button -->
            <styleClasses:BaseButton Width = "21" Height = "21" Command = "{Binding SetInAllCommand}">
                <Image Source = "/Arcanum_UI;component/Assets/Icons/20x20/Add20x20.png" />
                <styleClasses:BaseButton.ToolTip>
                    <TextBlock>
                        <Run Text = "Add this Institution to all selected locations. (Filters apply)" />
                    </TextBlock>
                </styleClasses:BaseButton.ToolTip>
            </styleClasses:BaseButton>

            <!-- Institution Name -->
            <TextBlock Text = "{Binding Name}" VerticalAlignment = "Center" FontSize = "14" Margin = "8, 0, 0, 0"
                       Foreground = "{StaticResource DefaultForeColorBrush}" />
        </DockPanel>

    </Border>
</UserControl>