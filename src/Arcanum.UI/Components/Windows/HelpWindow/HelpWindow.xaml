<styleClasses:BaseWindow x:Class = "Arcanum.UI.Components.Windows.HelpWindow.HelpWindow"
                         xmlns = "http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                         xmlns:x = "http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:mc = "http://schemas.openxmlformats.org/markup-compatibility/2006"
                         xmlns:d = "http://schemas.microsoft.com/expression/blend/2008"
                         xmlns:styleClasses = "clr-namespace:Arcanum.UI.Components.StyleClasses"
                         xmlns:commands = "clr-namespace:Arcanum.UI.Commands"
                         xmlns:converters = "clr-namespace:Arcanum.UI.Components.Converters"
                         xmlns:viewModels = "clr-namespace:Arcanum.UI.Components.Windows.HelpWindow.ViewModels"
                         xmlns:views = "clr-namespace:Arcanum.UI.Components.Windows.HelpWindow.Views"
                         xmlns:utils = "clr-namespace:Arcanum.Core.Utils;assembly=Arcanum.Core"
                         xmlns:globalStates = "clr-namespace:Arcanum.Core.GlobalStates;assembly=Arcanum.Core"
                         mc:Ignorable = "d" Title = "Help / Documentation" Height = "700" Width = "1200"
                         WindowStartupLocation = "CenterScreen" Background = "{StaticResource AccentGradientBrush}"
                         commands:CommandBinder.Scope = "{x:Static commands:CommandScopes.DIALOG}"
                         d:DataContext = "{d:DesignInstance viewModels:HelpWindowViewModel}">

    <styleClasses:BaseWindow.Resources>
        <ResourceDictionary>
            <converters:ResourceToGeometryConverter x:Key = "ResourceToGeometryConverter" />

            <!-- THE ENGINE: Mapping ViewModels to Views -->
            <DataTemplate DataType = "{x:Type viewModels:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>

            <DataTemplate DataType = "{x:Type viewModels:FeatureExplorerViewModel}">
                <views:FeatureExplorerView />
            </DataTemplate>

            <DataTemplate DataType = "{x:Type viewModels:CommandMapViewModel}">
                <views:CommandMapView />
            </DataTemplate>

            <!-- Sidebar Item Style -->
            <Style x:Key = "NavButtonStyle" TargetType = "ListBoxItem">
                <Setter Property = "Template">
                    <Setter.Value>
                        <ControlTemplate TargetType = "ListBoxItem">
                            <Border x:Name = "Bd" Padding = "15,10" BorderThickness = "1"
                                    BorderBrush = "{StaticResource DefaultBorderColorBrush}"
                                    Background = "{StaticResource DefaultBackColorBrush}" SnapsToDevicePixels = "True"
                                    CornerRadius = "5" Margin = "4"
                                    d:DataContext = "{d:DesignInstance viewModels:NavMenuItem}">
                                <StackPanel Orientation = "Horizontal">
                                    <!-- Placeholder for your Geometry Icons -->
                                    <Path
                                        Data = "{Binding IconKey, Converter={StaticResource ResourceToGeometryConverter}}"
                                        Stroke = "{TemplateBinding Foreground}" StrokeThickness = "1.2"
                                        StrokeLineJoin = "Round" StrokeStartLineCap = "Round"
                                        StrokeEndLineCap = "Round" Width = "16" Height = "16" Stretch = "Uniform"
                                        Margin = "0,0,12,0 " />
                                    <TextBlock Text = "{Binding Name}" VerticalAlignment = "Center" FontSize = "15" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property = "IsMouseOver" Value = "True">
                                    <Setter TargetName = "Bd" Property = "Background"
                                            Value = "{StaticResource BlueSelectionBackColorBrush}" />
                                </Trigger>
                                <Trigger Property = "IsSelected" Value = "True">
                                    <Setter TargetName = "Bd" Property = "Background"
                                            Value = "{StaticResource BlueAccentColorBrush}" />
                                    <Setter TargetName = "Bd" Property = "BorderBrush"
                                            Value = "{StaticResource BlueAccentColorBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source = "/Arcanum_UI;component/Assets/ArcanumShared/DefaultPalette.xaml" />
                <ResourceDictionary Source = "/Arcanum_UI;component/Assets/ArcanumShared/DefaultFonts.xaml" />
                <ResourceDictionary Source = "/Arcanum_UI;component/Assets/ArcanumShared/DefaultGeometry.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </styleClasses:BaseWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width = "200" /> <!-- Sidebar -->
            <ColumnDefinition Width = "*" />   <!-- Content -->
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column = "0">
            <Grid.RowDefinitions>
                <RowDefinition Height = "Auto" /> <!-- App Logo/Title -->
                <RowDefinition Height = "*" />    <!-- Menu -->
                <RowDefinition Height = "Auto" /> <!-- Settings/Version -->
            </Grid.RowDefinitions>

            <TextBlock Text = "A R C A N U M" FontSize = "25" FontWeight = "Bold" Margin = "0,0,0,20"
                       HorizontalAlignment = "Center" />
            <TextBlock Grid.Row = "0" FontSize = "18" Text = "{x:Static globalStates:AppData.ModName}"
                       HorizontalAlignment = "Center" Margin = "30" />

            <ListBox Grid.Row = "1" ItemsSource = "{Binding MenuItems}" SelectedItem = "{Binding SelectedMenuItem}"
                     ItemContainerStyle = "{StaticResource NavButtonStyle}" Background = "Transparent"
                     Foreground = "{StaticResource DefaultForeColorBrush}" BorderThickness = "0"
                     SelectionChanged = "Sidebar_SelectionChanged" />

            <StackPanel Grid.Row = "2" Margin = "20">
                <TextBlock Text = "{x:Static utils:VersionNumbers.CurrentVersionString}"
                           Foreground = "{StaticResource DefaultForeColorBrush}" HorizontalAlignment = "Left"
                           FontSize = "10" />
            </StackPanel>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Column = "1">
            <Grid.RowDefinitions>
                <RowDefinition Height = "Auto" /> <!-- Header / Search -->
                <RowDefinition Height = "*" />    <!-- Page Content -->
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row = "0" Margin = "4" Height = "50" Background = "{StaticResource DefaultBackColorBrush}"
                    BorderBrush = "{StaticResource DefaultBorderColorBrush}" BorderThickness = "1" CornerRadius = "8">
                <DockPanel LastChildFill = "True" Margin = "20,0">
                    <TextBlock Text = "{Binding CurrentPage.Title}" VerticalAlignment = "Center"
                               Foreground = "{StaticResource DefaultForeColorBrush}" FontSize = "18"
                               FontWeight = "SemiBold" />
                </DockPanel>
            </Border>

            <!-- PAGE CONTENT: Swaps automatically based on CurrentPage type -->
            <Border Grid.Row = "1" Padding = "20" Background = "{StaticResource DefaultBackColorBrush}"
                    CornerRadius = "8" Margin = "4, 0, 4,4" BorderBrush = "{StaticResource DefaultBorderColorBrush}"
                    BorderThickness = "1">
                <ContentControl Content = "{Binding CurrentPage}" />
            </Border>
        </Grid>
    </Grid>
</styleClasses:BaseWindow>